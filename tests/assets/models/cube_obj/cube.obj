# Unit cube centered at the origin (side length 1).
# Authored for SDL3D tests. Licensed under the SDL3D repository license.
mtllib cube.mtl

o Cube
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

vn  0.0  0.0 -1.0
vn  0.0  0.0  1.0
vn -1.0  0.0  0.0
vn  1.0  0.0  0.0
vn  0.0 -1.0  0.0
vn  0.0  1.0  0.0

vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

usemtl CubeMaterial
s off
# -Z face
f 1/1/1 4/4/1 3/3/1 2/2/1
# +Z face
f 5/1/2 6/2/2 7/3/2 8/4/2
# -X face
f 1/1/3 5/2/3 8/3/3 4/4/3
# +X face
f 2/1/4 3/2/4 7/3/4 6/4/4
# -Y face
f 1/1/5 2/2/5 6/3/5 5/4/5
# +Y face
f 4/1/6 8/2/6 7/3/6 3/4/6
