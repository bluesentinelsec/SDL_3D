            { "type": "pulse", "rate": 9.0, "color": [255, 245, 156, 255], "emissive_base": [0.75, 0.48, 0.08], "emissive_add": [0.65, 0.30, 0.0] }
          ]
        },
        { "type": "collision.circle", "radius": 0.22 },
        { "type": "motion.velocity_2d", "property": "velocity" }
      ]
    },
    {
      "name": "entity.ball.attract",
      "active": true,
      "tags": ["ball", "dynamic", "attract"],
      "transform": { "position": [0.0, 0.0, 0.12] },
      "properties": {
        "radius": { "type": "float", "value": 0.22 },
        "velocity": { "type": "vec2", "value": [0.0, 0.0] },
        "base_speed": { "type": "float", "value": 5.6 },
        "min_serve_angle": { "type": "float", "value": 0.22 },
        "speedup_per_hit": { "type": "float", "value": 0.28 },
        "max_speed": { "type": "float", "value": 10.0 },
        "max_serve_angle": { "type": "float", "value": 0.82 },
        "max_reflect_angle": { "type": "float", "value": 1.05 },
        "stagnant_reflect_epsilon": { "type": "float", "value": 0.08 },
        "stagnant_reflect_limit": { "type": "int", "value": 2 },
        "reflect_jitter_angle": { "type": "float", "value": 0.28 },
        "reflect_random_min_angle": { "type": "float", "value": 0.10 },
        "reflect_random_angle": { "type": "float", "value": 0.34 },
        "active_motion": { "type": "bool", "value": false }
      },
      "components": [
        {
          "type": "render.sphere",
          "radius": 0.22,
          "rings": 12,
          "slices": 18,
          "color": [255, 184, 82, 255],
          "emissive": true,
          "effects": [
            { "type": "pulse", "rate": 9.0, "color": [255, 245, 156, 255], "emissive_base": [0.75, 0.48, 0.08], "emissive_add": [0.65, 0.30, 0.0] }
          ]
        },
        { "type": "collision.circle", "radius": 0.22 },
        { "type": "motion.velocity_2d", "property": "velocity" }
      ]
    },
    {
      "name": "entity.score.player",
      "active": true,
      "tags": ["score", "player"],
      "properties": {
        "value": { "type": "int", "value": 0 }
      }
    },
    {
      "name": "entity.score.cpu",
      "active": true,
      "tags": ["score", "cpu"],
      "properties": {
        "value": { "type": "int", "value": 0 }
      }
    },
    {
      "name": "entity.match",
      "active": true,
      "tags": ["state", "match"],
      "properties": {
        "finished": { "type": "bool", "value": false },
        "winner": { "type": "string", "value": "none" },
        "field_half_height": { "type": "float", "value": 5.0 }
      }
    },
    {
      "name": "entity.presentation",
      "active": true,
      "tags": ["state", "presentation"],
      "properties": {
        "pause_flash": { "type": "float", "value": 0.0 },
        "border_flash": { "type": "float", "value": 0.0 },
        "paddle_flash": { "type": "float", "value": 0.0 },
        "border_flash_decay": { "type": "float", "value": 2.8 },
        "paddle_flash_decay": { "type": "float", "value": 4.0 },
        "pause_flash_speed": { "type": "float", "value": 3.0 }
      },
      "components": [
        { "type": "property.decay", "property": "border_flash", "rate_property": "border_flash_decay", "target": 0.0, "min": 0.0, "max": 1.0 },
        { "type": "property.decay", "property": "paddle_flash", "rate_property": "paddle_flash_decay", "target": 0.0, "min": 0.0, "max": 1.0 }
      ]
    },
    {
      "name": "entity.settings",
      "active": true,
      "tags": ["state", "settings"],
      "properties": {
        "difficulty": { "type": "string", "value": "normal" },
        "lighting_profile": { "type": "string", "value": "cinematic" },
        "fullscreen": { "type": "bool", "value": false },
        "input_style": { "type": "string", "value": "keyboard" }
      }
    },
    {
      "name": "entity.effect.ambient_particles",
      "active": true,
      "tags": ["effect", "particles"],
      "transform": { "position": [0.0, 0.0, 0.35] },
      "components": [
        {
          "type": "particles.emitter",
          "shape": "box",
          "extents": [8.8, 4.8, 0.18],
          "direction": [0.0, 1.0, 0.0],
          "spread": 1.1,
          "speed_min": 0.08,
          "speed_max": 0.45,
          "lifetime_min": 2.5,
          "lifetime_max": 5.0,
          "size_start": 0.035,
          "size_end": 0.012,
          "gravity": 0.0,
          "max_particles": 360,
          "emit_rate": 95.0,
          "color_start": [220, 235, 255, 105],
          "color_end": [255, 255, 255, 0],
          "emissive_intensity": 1.35,
          "camera_facing": true,
          "depth_test": true,
          "draw_emissive": [0.8, 0.9, 1.0],
          "random_seed": 19088743
        }
      ]
    }
  ],
  "signals": [
    "signal.game.start",
    "signal.ball.serve",
    "signal.ball.hit_wall",
    "signal.ball.hit_paddle",
    "signal.goal.player",
    "signal.goal.cpu",
    "signal.score.player",
    "signal.score.cpu",
    "signal.round.reset",
    "signal.match.player_won",
    "signal.match.cpu_won",
    "signal.match.reset",
    "signal.match.restart",
    "signal.camera.ball.toggle",
    "signal.attract.round_reset",
    "signal.presentation.flash_border",
    "signal.ui.menu.move",
    "signal.ui.menu.select",
    "signal.app.quit_fade_done"
  ],
  "logic": {
    "sensors": [
      {
        "name": "logic.goal.cpu",
        "type": "sensor.bounds_exit",
        "entity": "entity.ball",
        "axis": "x",
        "side": "min",
        "threshold": -9.22,
        "on_enter": "signal.goal.cpu"
      },
      {
        "name": "logic.goal.player",
        "type": "sensor.bounds_exit",
        "entity": "entity.ball",
        "axis": "x",
        "side": "max",
        "threshold": 9.22,
        "on_enter": "signal.goal.player"
      },
      {
        "name": "logic.wall.top_bottom",
        "type": "sensor.bounds_reflect",
        "entity": "entity.ball",
        "axis": "y",
        "min": -4.78,
        "max": 4.78,
        "on_reflect": "signal.ball.hit_wall"
      },
      {
        "name": "logic.paddle.player_contact",
        "type": "sensor.contact_2d",
        "a": "entity.ball",
        "b": "entity.paddle.player",
        "on_enter": "signal.ball.hit_paddle"
      },
      {
        "name": "logic.paddle.cpu_contact",
        "type": "sensor.contact_2d",
        "a": "entity.ball",
        "b": "entity.paddle.cpu",
        "on_enter": "signal.ball.hit_paddle"
      },
      {
        "name": "logic.attract.goal.left",
        "type": "sensor.bounds_exit",
        "entity": "entity.ball.attract",
        "axis": "x",
        "side": "min",
        "threshold": -9.22,
        "on_enter": "signal.attract.round_reset"
      },
      {
        "name": "logic.attract.goal.right",
        "type": "sensor.bounds_exit",
        "entity": "entity.ball.attract",
        "axis": "x",
        "side": "max",
        "threshold": 9.22,
        "on_enter": "signal.attract.round_reset"
      },
      {
        "name": "logic.attract.wall.top_bottom",
        "type": "sensor.bounds_reflect",
        "entity": "entity.ball.attract",
        "axis": "y",
        "min": -4.78,
        "max": 4.78,
        "on_reflect": "signal.ball.hit_wall"
      },
      {
        "name": "logic.attract.paddle_left_contact",
        "type": "sensor.contact_2d",
        "a": "entity.ball.attract",
        "b": "entity.paddle.attract_left",
        "on_enter": "signal.ball.hit_paddle"
      },
      {
        "name": "logic.attract.paddle_right_contact",
        "type": "sensor.contact_2d",
        "a": "entity.ball.attract",
        "b": "entity.paddle.attract_right",
        "on_enter": "signal.ball.hit_paddle"
      },
      {
        "name": "logic.camera.ball_toggle_input",
        "type": "sensor.input_pressed",
        "action": "action.camera.ball.toggle",
        "on_pressed": "signal.camera.ball.toggle"
      },
      {
        "name": "logic.match.restart_input",
        "type": "sensor.input_pressed",
        "action": "action.restart",
        "on_pressed": "signal.match.restart"
      }
    ],
    "timers": [
      {
        "name": "timer.round.serve",
        "delay": 1.0,
        "signal": "signal.ball.serve",
        "repeating": false
      }
    ],
    "bindings": [
      {
        "signal": "signal.ui.menu.move",
        "actions": [
          { "type": "audio.play_sfx", "sound": "sound.ui.move" }
        ]
      },
      {
        "signal": "signal.ui.menu.select",
        "actions": [
          { "type": "audio.play_sfx", "sound": "sound.ui.select" }
        ]
      },
      {
        "signal": "signal.game.start",
        "actions": [
          { "type": "timer.start", "timer": "timer.round.serve" }
        ]
      },
      {
        "signal": "signal.ball.serve",
        "actions": [
          { "type": "adapter.invoke", "adapter": "adapter.pong.serve_random", "target": "entity.ball" },
          { "type": "property.set", "target": "entity.ball", "key": "active_motion", "value": true }
        ]
      },
      {
        "signal": "signal.ball.hit_paddle",
        "actions": [
          { "type": "adapter.invoke", "adapter": "adapter.pong.reflect_from_paddle" },
          { "type": "audio.play_sfx", "sound": "sound.pong.hit" },
          { "type": "signal.emit", "signal": "signal.presentation.flash_border" }
        ]
      },
      {
        "signal": "signal.ball.hit_wall",
        "actions": [
          { "type": "audio.play_sfx", "sound": "sound.pong.hit", "volume": 0.35 },
          { "type": "signal.emit", "signal": "signal.presentation.flash_border" }
        ]
      },
      {
        "signal": "signal.presentation.flash_border",
        "actions": [
          { "type": "property.set", "target": "entity.presentation", "key": "border_flash", "value": 1.0 },
          { "type": "property.set", "target": "entity.presentation", "key": "paddle_flash", "value": 1.0 }
        ]
      },
      {
        "signal": "signal.goal.player",
        "actions": [
          { "type": "signal.emit", "signal": "signal.score.player" }
        ]
      },
      {
        "signal": "signal.goal.cpu",
        "actions": [
          { "type": "signal.emit", "signal": "signal.score.cpu" }
        ]
      },
      {
        "signal": "signal.score.player",
        "actions": [
          { "type": "audio.play_sfx", "sound": "sound.pong.score" },
          { "type": "property.add", "target": "entity.score.player", "key": "value", "value": 1 },
          { "type": "signal.emit", "signal": "signal.round.reset" },
          {
            "type": "branch",
            "if": {
              "type": "property.compare",
              "target": "entity.score.player",
              "key": "value",
              "op": ">=",
              "value": 10
            },
            "then": [
              { "type": "signal.emit", "signal": "signal.match.player_won" }
            ],
            "else": [
              { "type": "timer.start", "timer": "timer.round.serve" }
            ]
          }
        ]
      },
      {
        "signal": "signal.score.cpu",
        "actions": [
          { "type": "audio.play_sfx", "sound": "sound.pong.score" },
          { "type": "property.add", "target": "entity.score.cpu", "key": "value", "value": 1 },
          { "type": "signal.emit", "signal": "signal.round.reset" },
          {
            "type": "branch",
            "if": {
              "type": "property.compare",
              "target": "entity.score.cpu",
              "key": "value",
              "op": ">=",
              "value": 10
            },
            "then": [
              { "type": "signal.emit", "signal": "signal.match.cpu_won" }
            ],
            "else": [
              { "type": "timer.start", "timer": "timer.round.serve" }
            ]
          }
        ]
      },
      {
        "signal": "signal.match.player_won",
        "actions": [
          { "type": "property.set", "target": "entity.match", "key": "finished", "value": true },
          { "type": "property.set", "target": "entity.match", "key": "winner", "value": "player" }
        ]
      },
      {
        "signal": "signal.match.cpu_won",
        "actions": [
          { "type": "property.set", "target": "entity.match", "key": "finished", "value": true },
          { "type": "property.set", "target": "entity.match", "key": "winner", "value": "cpu" }
        ]
      },
      {
        "signal": "signal.round.reset",
        "actions": [
          { "type": "property.set", "target": "entity.ball", "key": "active_motion", "value": false },
          { "type": "property.set", "target": "entity.ball", "key": "velocity", "value": [0.0, 0.0] },
          { "type": "property.set", "target": "entity.ball", "key": "has_last_reflect_y", "value": false },
          { "type": "property.set", "target": "entity.ball", "key": "stagnant_reflect_count", "value": 0 },
          { "type": "transform.set_position", "target": "entity.ball", "position": [0.0, 0.0, 0.12] },
          { "type": "transform.set_position", "target": "entity.paddle.player", "position": [-8.0, 0.0, 0.0] },
          { "type": "transform.set_position", "target": "entity.paddle.cpu", "position": [8.0, 0.0, 0.0] }
        ]
      },
      {
        "signal": "signal.attract.round_reset",
        "actions": [
          { "type": "property.set", "target": "entity.ball.attract", "key": "active_motion", "value": false },
          { "type": "property.set", "target": "entity.ball.attract", "key": "velocity", "value": [0.0, 0.0] },
          { "type": "property.set", "target": "entity.ball.attract", "key": "has_last_reflect_y", "value": false },
          { "type": "property.set", "target": "entity.ball.attract", "key": "stagnant_reflect_count", "value": 0 },
          { "type": "transform.set_position", "target": "entity.ball.attract", "position": [0.0, 0.0, 0.12] },
          { "type": "transform.set_position", "target": "entity.paddle.attract_left", "position": [-8.0, 0.0, 0.0] },
          { "type": "transform.set_position", "target": "entity.paddle.attract_right", "position": [8.0, 0.0, 0.0] },
          { "type": "adapter.invoke", "adapter": "adapter.pong.serve_random", "target": "entity.ball.attract" },
          { "type": "property.set", "target": "entity.ball.attract", "key": "active_motion", "value": true }
        ]
      },
      {
        "signal": "signal.match.reset",
        "actions": [
          { "type": "property.set", "target": "entity.score.player", "key": "value", "value": 0 },
          { "type": "property.set", "target": "entity.score.cpu", "key": "value", "value": 0 },
          { "type": "property.set", "target": "entity.match", "key": "finished", "value": false },
          { "type": "property.set", "target": "entity.match", "key": "winner", "value": "none" },
          { "type": "property.set", "target": "entity.presentation", "key": "border_flash", "value": 0.0 },
          { "type": "property.set", "target": "entity.presentation", "key": "paddle_flash", "value": 0.0 },
          { "type": "signal.emit", "signal": "signal.round.reset" }
        ]
      },
      {
        "signal": "signal.match.restart",
        "actions": [
          {
            "type": "branch",
            "if": {
              "type": "property.compare",
              "target": "entity.match",
              "key": "finished",
              "op": "==",
              "value": true
            },
            "then": [
              { "type": "signal.emit", "signal": "signal.match.reset" },
              { "type": "signal.emit", "signal": "signal.game.start" }
            ],
            "else": []
          }
        ]
      },
      {
        "signal": "signal.camera.ball.toggle",
        "actions": [
          { "type": "camera.toggle", "camera": "camera.ball_chase", "fallback": "camera.overhead" }
        ]
      }
    ]
  },
  "adapters": [
    {
      "name": "adapter.pong.serve_random",
      "kind": "action",
      "script": "script.pong",
      "function": "serve_random",
      "description": "Choose a non-extreme random serve vector for the ball."
    },
    {
      "name": "adapter.pong.reflect_from_paddle",
      "kind": "action",
      "script": "script.pong",
      "function": "reflect_from_paddle",
      "description": "Reflect ball velocity using Pong-specific hit-offset deflection."
    },
    {
      "name": "adapter.pong.cpu_track_ball",
      "kind": "controller",
      "script": "script.pong",
      "function": "cpu_track_ball",
      "description": "Move the CPU paddle toward the current ball position."
    }
  ]
}
