{
  "schema": "sdl3d.scene.v0",
  "name": "scene.title",
  "updates_game": false,
  "renders_world": false,
  "entities": [],
  "input": {
    "actions": [
      "action.menu.up",
      "action.menu.down",
      "action.menu.select"
    ]
  },
  "transitions": {
    "enter": "scene_in",
    "exit": "scene_out"
  },
  "menus": [
    {
      "name": "menu.title",
      "up_action": "action.menu.up",
      "down_action": "action.menu.down",
      "select_action": "action.menu.select",
      "move_signal": "signal.ui.menu.move",
      "select_signal": "signal.ui.menu.select",
      "selected": 0,
      "items": [
        { "label": "Play", "scene": "scene.play" },
        { "label": "Options", "scene": "scene.options" },
        { "label": "Exit", "quit": true }
      ]
    }
  ],
  "ui": {
    "text": [
      {
        "name": "ui.title.logo",
        "font": "font.title",
        "text": "PONG",
        "x": 0.5,
        "y": 0.21,
