        "color": [242, 248, 255, 255]
      }
    ],
    "menus": [
      {
        "name": "ui.title.menu",
        "menu": "menu.title",
        "font": "font.hud",
        "x": 0.5,
        "y": 0.48,
        "gap": 0.09,
        "normalized": true,
        "align": "center",
        "color": [225, 236, 255, 245],
        "selected_color": [255, 245, 208, 255],
        "selected_pulse_alpha": true,
        "cursor": {
          "text": ">",
          "offset_x": -0.12,
          "align": "center",
          "color": [255, 222, 140, 255],
          "pulse_alpha": true
        }
      }
    ]
  }
