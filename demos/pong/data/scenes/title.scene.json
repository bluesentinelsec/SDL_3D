{
  "schema": "sdl3d.scene.v0",
  "name": "scene.title",
  "updates_game": true,
  "renders_world": true,
  "camera": "camera.overhead",
  "entities": [
    "entity.field.base",
    "entity.field.border.top",
    "entity.field.border.bottom",
    "entity.field.border.left",
    "entity.field.border.right",
    "entity.field.center_ticks",
    "entity.paddle.attract_left",
    "entity.paddle.attract_right",
    "entity.ball.attract",
    "entity.light.lamp",
    "entity.presentation",
    "entity.effect.ambient_particles"
  ],
  "input": {
    "actions": [
      "action.menu.up",
      "action.menu.down",
      "action.menu.select"
    ]
  },
  "transitions": {
    "enter": "scene_in",
    "exit": "scene_out"
  },
  "activity": {
    "enabled": true,
    "input": "any",
    "consume_wake_input": true,
    "block_menus_on_wake": true,
    "block_scene_shortcuts_on_wake": true,
    "idle_after": 5.0,
    "on_enter": [
      { "type": "camera.set", "camera": "camera.overhead" },
      { "type": "signal.emit", "signal": "signal.attract.round_reset" },
      { "type": "ui.animate", "target": "ui.title.logo", "property": "alpha", "to": 1.0, "duration": 0.0 },
      { "type": "ui.animate", "target": "ui.title.menu", "property": "alpha", "to": 1.0, "duration": 0.0 }
    ],
    "on_idle": [
      { "type": "ui.animate", "target": "ui.title.logo", "property": "alpha", "to": 0.0, "duration": 0.65, "easing": "out_quad" },
      { "type": "ui.animate", "target": "ui.title.menu", "property": "alpha", "to": 0.0, "duration": 0.65, "easing": "out_quad" }
    ],
    "on_active": [
      { "type": "ui.animate", "target": "ui.title.logo", "property": "alpha", "to": 1.0, "duration": 0.20, "easing": "out_quad" },
      { "type": "ui.animate", "target": "ui.title.menu", "property": "alpha", "to": 1.0, "duration": 0.20, "easing": "out_quad" }
    ],
    "periodic": [
      {
        "interval": 12.0,
        "actions": [
          { "type": "camera.toggle", "camera": "camera.attract_ball_chase", "fallback": "camera.overhead" }
        ]
      },
      {
        "interval": 60.0,
        "reset_idle": true,
        "actions": [
          { "type": "ui.animate", "target": "ui.title.logo", "property": "alpha", "to": 1.0, "duration": 0.35, "easing": "out_quad" },
          { "type": "ui.animate", "target": "ui.title.menu", "property": "alpha", "to": 1.0, "duration": 0.35, "easing": "out_quad" }
        ]
      }
    ]
  },
  "menus": [
    {
      "name": "menu.title",
      "up_action": "action.menu.up",
      "down_action": "action.menu.down",
      "select_action": "action.menu.select",
      "move_signal": "signal.ui.menu.move",
      "select_signal": "signal.ui.menu.select",
      "selected": 0,
      "items": [
        {
          "label": "Single Player",
          "scene": "scene.play",
          "scene_state": { "key": "match_mode", "value": "single" }
        },
        {
          "label": "Multiplayer",
          "scene": "scene.multiplayer",
          "scene_state": { "key": "match_mode", "value": "multiplayer" }
        },
        { "label": "Options", "scene": "scene.options", "return_to": "scene.title", "return_paused": false },
        { "label": "Exit", "quit": true }
      ]
    }
  ],
  "ui": {
    "text": [
      {
        "name": "ui.title.logo",
        "font": "font.title",
        "text": "PONG",
        "x": 0.5,
        "y": 0.21,
        "normalized": true,
        "centered": true,
        "color": [242, 248, 255, 255]
      }
    ],
    "menus": [
      {
        "name": "ui.title.menu",
        "menu": "menu.title",
        "font": "font.hud",
        "x": 0.45,
        "y": 0.48,
        "gap": 0.09,
        "normalized": true,
        "align": "left",
        "color": [225, 236, 255, 245],
        "selected_color": [255, 245, 208, 255],
        "selected_pulse_alpha": true,
        "cursor": {
          "text": ">",
          "offset_x": -0.035,
          "align": "right",
          "color": [255, 222, 140, 255],
          "pulse_alpha": true
        }
      }
    ]
  }
}
